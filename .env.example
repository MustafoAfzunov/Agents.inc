# Copy to ``.env`` and adjust. All values here are safe development defaults.

DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*

# Ingestion configuration
TECHCRUNCH_TOPIC_URL=https://techcrunch.com/tag/openai/
DEFAULT_RESCAN_PAGES=2
HTTP_TIMEOUT_SECONDS=20
HTTP_USER_AGENT=news-graph-bot/1.0 (+https://example.com/bot)
EXTRACTION_MAX_CHARS=12000

# Extraction provider:
#   mock   - regex, offline, no extra deps (default)
#   spacy  - offline NER only (`python -m spacy download en_core_web_sm`)
#   openai - OpenAI when the key works; auto-falls back to spaCy when quota/key fails
#   auto   - alias for openai
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Logging
LOG_LEVEL=INFO

# Postgres (only used by config.settings.prod)
# POSTGRES_DB=newsgraph
# POSTGRES_USER=newsgraph
# POSTGRES_PASSWORD=newsgraph
# POSTGRES_HOST=db
# POSTGRES_PORT=5432
